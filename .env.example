# --- Baza (libSQL / Turso) ---
# Lokalni razvoj: koristi lokalnu datoteku
DATABASE_URL="file:local.db"
# Produkcija (Vercel) — Turso:
# DATABASE_URL="libsql://ime-baze.turso.io"
# DATABASE_AUTH_TOKEN="tvoj-turso-token"

# --- Sesija ---
# Tajni ključ za potpis sesije (min 32 znaka). Generiraj: openssl rand -base64 48
SESSION_SECRET="promijeni-me-na-dugi-slucajni-niz-od-najmanje-32-znaka"

# --- War Era API ---
WARERA_API_KEY="tvoj-war-era-api-kljuc"
WARERA_API_BASE="https://api2.warera.io/trpc"
# Deep link baza za bitke
WARERA_APP_BASE="https://app.warera.io"

# --- Bootstrap admin ---
# Prvi admin racun (kreira se seed skriptom ako ne postoji)
BOOTSTRAP_ADMIN_CALLSIGN="zapovjednik"
